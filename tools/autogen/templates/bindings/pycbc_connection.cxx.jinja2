
// ==========================================================================================
// Key-Value Operations
// ==========================================================================================
{% for op in key_value_operations %}
static PyObject*
pycbc_connection__{{op.name}}__(pycbc_connection* self, PyObject* args, PyObject* kwargs)
{
    if (!validate_connection_and_args(self, args, kwargs, "{{op.name}}")) {
        return nullptr;
    }
    return self->conn->execute_kv_op<{{op.request_struct_full}}>(kwargs);
}
{% endfor %}
// ==========================================================================================
// Key-Value Multi Operations
// ==========================================================================================
{% for op in key_value_operations if op.has_multi %}
static PyObject*
pycbc_connection__{{op.name}}_multi__(pycbc_connection* self, PyObject* args, PyObject* kwargs)
{
    return handle_multi_kv_op<{{op.request_struct_full}}>(self, args, kwargs, "{{op.name}}_multi");
}
{% endfor %}
// ==========================================================================================
// Streaming Operations
// ==========================================================================================
{% for op in streaming_operations %}
static PyObject*
pycbc_connection__{{op.streaming_op_name}}__(pycbc_connection* self, PyObject* args, PyObject* kwargs)
{
    if (!validate_connection_and_args(self, args, kwargs, "{{op.name}}")) {
        return nullptr;
    }
    return self->conn->execute_streaming_op<{{op.request_struct_full}}>(kwargs);
}
{% endfor %}
{% for mgmt_group in mgmt_groups %}
// ==========================================================================================
// {{mgmt_group.pretty_name}} Management Operations
// ==========================================================================================
{% for op in mgmt_group.operations %}
static PyObject*
pycbc_connection__{{op.name}}__(pycbc_connection* self, PyObject* args, PyObject* kwargs)
{
    if (!validate_connection_and_args(self, args, kwargs, "{{op.name}}")) {
        return nullptr;
    }
    return self->conn->execute_mgmt_op<{{op.request_struct_full}}>(kwargs);
}
{% endfor %}
{% endfor %}
